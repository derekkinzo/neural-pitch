# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Node / frontend
/node_modules
/dist
/.vite
/coverage
*.tsbuildinfo

# Tauri build outputs
/src-tauri/target
/src-tauri/gen/schemas

# Tooling
.pre-commit-cache

# scripts/ci-local.sh per-step logs (cleaned on green, preserved on red)
/.ci-local-logs/
/.ci-local-last-failure.log

# Models / datasets (always fetched, never committed)
/models/
/tests/data/

# Recordings (developer scratch)
/recordings/

# OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
/.idea
/.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json

# Logs
/logs
*.log

# Playwright / E2E
/playwright-report/
/test-results/
/blob-report/
/tests/e2e/.auth

# Acceptance harness regenerated artifact (timestamp + cents change per run)
/.acceptance-reports/

# Live-shell smoke harness (timestamped screenshots + summary per run)
/.smoke-reports/

# Local libonnxruntime.so for the smoke harness — populated via
# `npm install --no-save --prefix .ort onnxruntime-node@1.21.0` and
# auto-resolved by `scripts/smoke-test.sh` so the local gate's ONNX
# tests / smoke runs do not block in dlopen.
/.ort/

# Local env
.env
.env.local
