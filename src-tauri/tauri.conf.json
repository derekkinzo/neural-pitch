{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeuralPitch",
  "version": "0.1.0",
  "identifier": "com.derekkinzo.neuralpitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeuralPitch",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/recordings/**", "$APPLOCALDATA/recordings/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "copyright": "Copyright © 2026 Derek Kinzo",
    "shortDescription": "Pitch-detection app for singers.",
    "longDescription": "Real-time pitch tuner with offline recording, contour analysis, vocal-range reports, and vibrato detection.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
